# Environment variables for test deployment (dev.portal.hotosm.org)

# Portal Base URL (auto-detects test environment from dev. prefix)
PORTAL_BASE_URL=https://dev.portal.hotosm.org

# Database
POSTGRES_USER=portal
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=portal

# Auth
COOKIE_SECRET=CHANGE_ME_MIN_32_BYTES

# OSM OAuth (register at https://www.openstreetmap.org/oauth2/applications/new)
OSM_CLIENT_ID=your-osm-client-id
OSM_CLIENT_SECRET=your-osm-client-secret

# Admin emails (comma-separated)
ADMIN_EMAILS=admin@hotosm.org

# S3 object storage for plan images (required for image upload to work)
# Use a real S3 bucket or point to a MinIO instance
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_BUCKET_NAME=your-bucket-name
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
